{
  "name": "lint-on-save",
  "version": "1.0.0",
  "description": "Run linter automatically when source files are saved",
  "event": "fileEdited",
  "condition": {
    "field": "path",
    "operator": "matches",
    "value": "\\.(ts|tsx|js|jsx)$"
  },
  "action": {
    "type": "run-script",
    "target": "npm run lint -- --fix",
    "params": {}
  },
  "enabled": true,
  "priority": 100
}