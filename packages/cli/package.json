{
  "name": "@agentflow/cli",
  "version": "0.1.0",
  "description": "AgentFlow CLI — parse, validate, export agent workflows from the command line.",
  "main": "src/parser.ts",
  "bin": {
    "agentflow": "bin/cli.js"
  },
  "exports": {
    ".": "./src/parser.ts",
    "./parser": "./src/parser.ts",
    "./branding": "./src/branding.ts",
    "./library": "./src/library.ts",
    "./pretty-printer": "./src/pretty-printer.ts",
    "./structured-exporter": "./src/structured-exporter.ts",
    "./git/*": "./src/git/*.ts",
    "./mcp/*": "./src/mcp/*.ts",
    "./services/*": "./src/services/*.ts",
    "./svc-utils/*": "./src/svc-utils/*.ts",
    "./utils/*": "./src/utils/*.ts",
    "./transport/*": "./src/transport/*.ts",
    "./export": "./src/export/index.ts"
  },
  "dependencies": {
    "@agentflow/core": "*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "minimatch": "^9.0.0",
    "simple-git": "^3.33.0",
    "tsx": "^4.21.0",
    "zod": "^3.25.76"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
