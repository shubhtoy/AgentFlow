{
  "name": "auto-format-on-save",
  "version": "1.0.0",
  "description": "Format code automatically when files are saved",
  "event": "fileEdited",
  "condition": {
    "field": "path",
    "operator": "matches",
    "value": "\\.(ts|tsx|js|jsx|py|java|go|rs|css|json)$"
  },
  "action": {
    "type": "run-script",
    "target": "npx prettier --write {path}",
    "params": {}
  },
  "enabled": false,
  "priority": 50
}
