{
  "name": "security-scan-on-commit",
  "version": "1.0.0",
  "description": "Run a security scan before tool invocations that modify code",
  "event": "preToolUse",
  "condition": {
    "field": "toolName",
    "operator": "contains",
    "value": "commit"
  },
  "action": {
    "type": "run-script",
    "target": "npm audit --production",
    "params": {}
  },
  "enabled": false,
  "priority": 300
}
