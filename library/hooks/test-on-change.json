{
  "name": "test-on-change",
  "description": "Run related tests when source files change to catch regressions immediately",
  "event": "fileEdited",
  "condition": {
    "field": "path",
    "operator": "matches",
    "value": "\\.(ts|tsx|js|jsx|py)$"
  },
  "action": {
    "type": "run-script",
    "target": "npm test -- --related"
  },
  "enabled": false,
  "priority": 200
}
