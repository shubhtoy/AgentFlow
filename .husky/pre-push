#!/usr/bin/env sh
# Mandatory pre-push checks. Tests must pass or the push is aborted.
set -e

echo "── pre-push: running tests ──"
npm test

echo ""
echo "── pre-push: docs prune check (advisory — never fails the push on its own) ──"
npm run docs:check

echo ""
echo "── pre-push: refreshing dashboard snapshot ──"
npm run dashboard
if ! git diff --quiet studio/public/dashboard.html 2>/dev/null; then
  echo ""
  echo "NOTE: studio/public/dashboard.html changed (fresh commit/test/lint counts)."
  echo "      Not auto-committed — per git-safety, stage + commit it yourself if you want"
  echo "      this push's deploy to include the refreshed snapshot:"
  echo "        git add studio/public/dashboard.html && git commit -m 'chore: refresh dashboard'"
fi
