# AgentFlow Studio Environment Variables

# ── Git Authentication ──
# OAuth providers (optional — buttons only show when configured)
# GitHub: https://github.com/settings/applications/new (callback: http://localhost:3000/api/auth/callback/github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab: https://gitlab.com/-/user_settings/applications (callback: http://localhost:3000/api/auth/callback/gitlab)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Bitbucket: https://bitbucket.org/account/settings/app-authorizations/ (callback: http://localhost:3000/api/auth/callback/bitbucket)
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# GitHub Device Flow (only needs client ID, no secret)
# Same GITHUB_CLIENT_ID as above — if set without secret, device flow is used

# ── Platform Mode ──
# Local git mode — enables server-side git with SSH support (default: true when local)
AF_LOCAL_GIT=true

# Required for next-auth session encryption
AUTH_SECRET=  # Generate with: openssl rand -base64 32

# ── AI Keys (for CopilotKit) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
