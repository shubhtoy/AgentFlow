{
  "agent-spec": {
    "id": "agent-spec",
    "name": "Open Agent Spec",
    "website": "https://openagentspec.dev",
    "version": "26.1.0",
    "serializer": "tsagentspec",
    "mapping": {
      "identity": {
        "transform": "to-agent-system-prompt"
      },
      "instructions": {
        "transform": "to-system-prompt-chunk"
      },
      "skills": {
        "transform": "to-agent-specialization"
      },
      "capabilities": {
        "builtin": {
          "transform": "to-builtin-tool"
        },
        "script": {
          "transform": "to-server-tool"
        },
        "mcp": {
          "transform": "to-mcp-tool"
        },
        "package": {
          "transform": "to-client-tool"
        }
      },
      "nodes": {
        "step": {
          "transform": "to-agent-node"
        },
        "sub-workflow": {
          "transform": "to-flow-node"
        }
      },
      "edges": {
        "unconditional": {
          "transform": "to-control-flow-edge"
        },
        "conditional": {
          "transform": "to-branching-node"
        }
      },
      "memory": {
        "transform": null
      },
      "hooks": {
        "transform": null
      }
    },
    "mcp": {
      "format": "agent-spec-mcp",
      "components": [
        "MCPTool",
        "MCPToolBox",
        "StdioTransport",
        "SSETransport",
        "StreamableHTTPTransport"
      ]
    }
  },
  "aider": {
    "id": "aider",
    "name": "Aider",
    "website": "https://aider.chat",
    "paths": {
      "root": ".",
      "conventions": "CONVENTIONS.md"
    },
    "mapping": {
      "identity": {
        "target": "CONVENTIONS.md",
        "transform": "concatenate",
        "sources": [
          "identity",
          "instructions"
        ]
      },
      "instructions": {
        "target": null,
        "note": "Merged into CONVENTIONS.md via identity concatenation"
      },
      "skills": {
        "target": "CONVENTIONS.md",
        "transform": "concatenate",
        "append": true
      },
      "capabilities": {
        "mcp": {
          "target": null
        },
        "non-mcp": {
          "embed": "conventions"
        }
      },
      "memory": {
        "target": null
      },
      "hooks": {
        "target": null
      }
    },
    "mcp": {
      "configPath": null,
      "format": null
    }
  },
  "antigravity": {
    "id": "antigravity",
    "name": "Antigravity",
    "website": "https://antigravity.dev",
    "paths": {
      "root": ".antigravity",
      "skills": ".antigravity/skills/"
    },
    "mapping": {
      "identity": {
        "target": ".antigravity/AGENTS.md",
        "transform": "copy"
      },
      "instructions": {
        "target": ".antigravity/skills/{name}/SKILL.md",
        "transform": "to-skill-dir"
      },
      "skills": {
        "target": ".antigravity/skills/{name}/",
        "transform": "copy-dir"
      },
      "capabilities": {
        "mcp": {
          "target": null
        },
        "non-mcp": {
          "embed": "identity"
        }
      },
      "memory": {
        "target": null
      },
      "hooks": {
        "target": null
      }
    },
    "mcp": {
      "configPath": null,
      "format": null
    }
  },
  "claude-code": {
    "id": "claude-code",
    "name": "Claude Code",
    "website": "https://claude.ai/code",
    "agentsmd": true,
    "paths": {
      "root": ".claude",
      "identity": "CLAUDE.md",
      "rules": ".claude/rules/",
      "skills": ".claude/skills/",
      "settings": ".claude/settings.json"
    },
    "mapping": {
      "identity": {
        "target": "CLAUDE.md",
        "transform": "rename"
      },
      "instructions": {
        "target": ".claude/rules/{name}.md",
        "transform": "copy"
      },
      "skills": {
        "target": ".claude/skills/{name}/",
        "transform": "copy-dir"
      },
      "capabilities": {
        "mcp": {
          "target": ".claude/settings.json",
          "transform": "merge-mcp-config"
        },
        "non-mcp": {
          "embed": "identity"
        }
      },
      "memory": {
        "target": null
      },
      "hooks": {
        "target": null
      }
    },
    "mcp": {
      "configPath": ".claude/settings.json",
      "format": "claude-settings",
      "schema": {
        "mcpServers": {
          "{name}": {
            "command": "{command}",
            "args": "{args}",
            "env": "{env}"
          }
        }
      }
    }
  },
  "copilot": {
    "id": "copilot",
    "name": "GitHub Copilot",
    "website": "https://github.com/features/copilot",
    "paths": {
      "root": ".github",
      "agents": ".github/agents/",
      "mcp": ".github/copilot/mcp.json"
    },
    "mapping": {
      "identity": {
        "target": ".github/agents/identity.md",
        "transform": "copy"
      },
      "instructions": {
        "target": ".github/agents/{name}.md",
        "transform": "copy"
      },
      "skills": {
        "target": ".github/agents/{name}.md",
        "transform": "flatten-skill"
      },
      "capabilities": {
        "mcp": {
          "target": ".github/copilot/mcp.json",
          "transform": "merge-mcp-config"
        },
        "non-mcp": {
          "embed": "identity"
        }
      },
      "memory": {
        "target": null
      },
      "hooks": {
        "target": null
      }
    },
    "mcp": {
      "configPath": ".github/copilot/mcp.json",
      "format": "mcp-standard",
      "schema": {
        "mcpServers": {
          "{name}": {
            "command": "{command}",
            "args": "{args}"
          }
        }
      }
    }
  },
  "cursor": {
    "id": "cursor",
    "name": "Cursor",
    "website": "https://cursor.com",
    "paths": {
      "root": ".cursor",
      "rules": ".cursor/rules/",
      "mcp": ".cursor/mcp.json"
    },
    "mapping": {
      "identity": {
        "target": ".cursor/rules/identity.mdc",
        "transform": "to-mdc",
        "frontmatter": {
          "description": "Workspace identity and agent persona",
          "alwaysApply": true
        }
      },
      "instructions": {
        "target": ".cursor/rules/{name}.mdc",
        "transform": "to-mdc",
        "frontmatter": {
          "description": "from:instructions.description",
          "globs": "from:instructions.platforms.cursor.globs",
          "alwaysApply": "from:instructions.platforms.cursor.alwaysApply"
        }
      },
      "skills": {
        "target": ".cursor/rules/{name}.mdc",
        "transform": "flatten-skill",
        "frontmatter": {
          "description": "from:skills.description"
        }
      },
      "capabilities": {
        "mcp": {
          "target": ".cursor/mcp.json",
          "transform": "merge-mcp-config"
        },
        "non-mcp": {
          "embed": "rules"
        }
      },
      "memory": {
        "target": null
      },
      "hooks": {
        "target": null
      }
    },
    "mcp": {
      "configPath": ".cursor/mcp.json",
      "format": "mcp-standard",
      "schema": {
        "mcpServers": {
          "{name}": {
            "command": "{command}",
            "args": "{args}"
          }
        }
      }
    }
  },
